{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "log:default",
    "opener:default",
    "upload:default",
    "fs:create-app-specific-dirs",
    "fs:deny-default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPCACHE/images",
        "$APPCACHE/images/**/*"
      ]
    }
  ]
}
